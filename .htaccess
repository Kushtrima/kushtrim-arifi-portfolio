# ===============================================================
# kushtrimarifi.com — Apache / cPanel configuration
# Performance, SEO, security headers
# ===============================================================

# ---- 1. Force HTTPS + canonical host (www → non-www) ----
RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} !=on
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Force non-www (canonical = https://kushtrimarifi.com)
RewriteCond %{HTTP_HOST} ^www\.kushtrimarifi\.com$ [NC]
RewriteRule ^(.*)$ https://kushtrimarifi.com/$1 [L,R=301]

# ---- 1b. 301 redirects: old flat URLs → new /work/ structure ----
# These preserve SEO authority and prevent broken links from any external sites
RewriteRule ^cityhotel\.html$       /work/cityhotel.html       [R=301,L]
RewriteRule ^hbs-website\.html$     /work/hbs-website.html     [R=301,L]
RewriteRule ^jetonikeramika\.html$  /work/jetonikeramika.html  [R=301,L]
RewriteRule ^ennur\.html$           /work/ennur.html           [R=301,L]
RewriteRule ^doratec\.html$         /work/doratec.html         [R=301,L]
RewriteRule ^mardal\.html$          /work/mardal.html          [R=301,L]
RewriteRule ^spitex\.html$          /work/spitex.html          [R=301,L]
RewriteRule ^stplaner\.html$        /work/stplaner.html        [R=301,L]
RewriteRule ^monun\.html$           /work/monun.html           [R=301,L]
RewriteRule ^alba\.html$            /work/alba.html            [R=301,L]
RewriteRule ^hbs\.html$             /work/hbs.html             [R=301,L]
RewriteRule ^wmk\.html$             /work/wmk.html             [R=301,L]
RewriteRule ^riesen\.html$          /work/riesen.html          [R=301,L]
RewriteRule ^baren\.html$           /work/baren.html           [R=301,L]
RewriteRule ^socialmedia\.html$     /work/socialmedia.html     [R=301,L]
RewriteRule ^printing\.html$        /work/printing.html        [R=301,L]
RewriteRule ^etno\.html$            /work/etno.html            [R=301,L]

# ---- 2. Pretty URLs (drop .html extension) ----
# Disabled by default — turning this on requires updating all internal links to drop .html
# Uncomment when ready:
# RewriteCond %{REQUEST_FILENAME} !-d
# RewriteCond %{REQUEST_FILENAME}.html -f
# RewriteRule ^([^.]+)$ $1.html [NC,L]

# ---- 3. Custom error pages ----
ErrorDocument 404 /404.html

# ---- 4. GZIP / Brotli compression ----
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json application/xml application/rss+xml application/atom+xml image/svg+xml application/x-font-ttf application/vnd.ms-fontobject font/opentype
</IfModule>

<IfModule mod_brotli.c>
    AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# ---- 5. Cache-Control (Expires) headers ----
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault                                      "access plus 1 month"

    # Images — long cache
    ExpiresByType image/jpeg                            "access plus 1 year"
    ExpiresByType image/png                             "access plus 1 year"
    ExpiresByType image/webp                            "access plus 1 year"
    ExpiresByType image/avif                            "access plus 1 year"
    ExpiresByType image/gif                             "access plus 1 year"
    ExpiresByType image/svg+xml                         "access plus 1 year"
    ExpiresByType image/x-icon                          "access plus 1 year"

    # Fonts
    ExpiresByType font/woff                             "access plus 1 year"
    ExpiresByType font/woff2                            "access plus 1 year"
    ExpiresByType application/font-woff                 "access plus 1 year"
    ExpiresByType application/font-woff2                "access plus 1 year"

    # CSS / JS
    ExpiresByType text/css                              "access plus 1 month"
    ExpiresByType application/javascript                "access plus 1 month"
    ExpiresByType text/javascript                       "access plus 1 month"

    # HTML — short cache
    ExpiresByType text/html                             "access plus 1 hour"

    # Manifest / data
    ExpiresByType application/manifest+json             "access plus 1 week"
    ExpiresByType application/json                      "access plus 0 seconds"
    ExpiresByType application/xml                       "access plus 0 seconds"
    ExpiresByType text/xml                              "access plus 0 seconds"
</IfModule>

# ---- 6. Security headers ----
<IfModule mod_headers.c>
    # Force HTTPS for 6 months (relax to 2 years once you're sure)
    Header always set Strict-Transport-Security "max-age=15552000; includeSubDomains"

    # Block clickjacking
    Header always set X-Frame-Options "SAMEORIGIN"

    # Block content sniffing
    Header always set X-Content-Type-Options "nosniff"

    # Sane referrer policy
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Conservative permissions
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=()"

    # Prevent indexing of the resume PDF (so it can't outrank the homepage for your name)
    <FilesMatch "\.pdf$">
        Header set X-Robots-Tag "noindex, follow"
    </FilesMatch>

    # Cache-Control max-age in seconds — explicit override for selected types
    <FilesMatch "\.(jpg|jpeg|png|gif|webp|avif|svg|ico|woff|woff2)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "public, max-age=2592000"
    </FilesMatch>
    <FilesMatch "\.html$">
        Header set Cache-Control "public, max-age=3600, must-revalidate"
    </FilesMatch>
</IfModule>

# ---- 7. Correct MIME types ----
<IfModule mod_mime.c>
    AddType image/svg+xml                .svg
    AddType image/webp                   .webp
    AddType image/avif                   .avif
    AddType application/manifest+json    .webmanifest
    AddType font/woff2                   .woff2
    AddType font/woff                    .woff
</IfModule>

# ---- 8. Block hidden / sensitive files ----
<FilesMatch "^\.">
    Require all denied
</FilesMatch>
<FilesMatch "(\.md|\.py|\.cdr|\.bak)$">
    Require all denied
</FilesMatch>
